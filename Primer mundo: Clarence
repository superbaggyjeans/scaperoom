<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Mundo Clarence</title>
  <script src="https://aframe.io/releases/1.4.0/aframe.min.js"></script>
  <script src="js/clarence.js"></script>
</head>

<body>
<a-scene>

  <!-- Cámara -->
  <a-entity camera look-controls position="0 1.6 3">
    <a-cursor></a-cursor>
  </a-entity>

  <!-- Suelo (estilo patio de Clarence) -->
  <a-plane rotation="-90 0 0" width="30" height="30" color="#7ED957"></a-plane>

  <!-- PERSONAJE: CLARENCE -->
  <a-entity id="personaje"
    gltf-model="#clarenceModel"
    position="0 0 -3"
    scale="1 1 1"
    class="clickable">
  </a-entity>

  <!-- OBJETO PERDIDO -->
  <a-entity id="objeto"
    gltf-model="#objetoModel"
    position="3 0 -5"
    scale="0.6 0.6 0.6"
    visible="false"
    class="clickable">
  </a-entity>

  <!-- PORTAL -->
  <a-entity id="portal"
    gltf-model="#portalModel"
    position="0 0 -9"
    scale="1 1 1"
    visible="false"
    class="clickable">
  </a-entity>

  <!-- DIÁLOGO -->
  <a-text id="dialogo"
    position="0 2.2 -2"
    align="center"
    width="7"
    color="black"
    visible="false">
  </a-text>

  <!-- ASSETS -->
  <a-assets>
    <a-asset-item id="clarenceModel" src="clarence_hip_hop_dancing.glb"></a-asset-item>
    <a-asset-item id="objetoModel" src="assets/objeto_clarence.glb"></a-asset-item>
    <a-asset-item id="portalModel" src="assets/portal.glb"></a-asset-item>
  </a-assets>

</a-scene>
</body>
</html>